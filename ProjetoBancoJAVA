class Pessoa {

    private String nome;
    private String CPF;
    private String email;
    private String endereco;
    private int conta;
    private int senha;
    private double dinheiro;

    public Pessoa(String nome, String CPF, String email, String endereco, int conta, double dinheiro, int senha) {
        this.nome = nome;
        this.CPF = CPF;
        this.email = email;
        this.endereco = endereco;
        this.conta = conta;
        this.dinheiro = dinheiro;
        this.senha = senha;
    }

    public void setDinheiro(double dinheiro) {
        this.dinheiro = dinheiro;
    }

    public String getNome() {
        return nome;
    }

    public String getCPF() {
        return CPF;
    }

    public String getEmail() {
        return email;
    }

    public String getEndereco() {
        return endereco;
    }

    public int getConta() {
        return conta;
    }

    public double getDinheiro() {
        return dinheiro;
    }

    public int getSenha() {
        return senha;
    }

}

